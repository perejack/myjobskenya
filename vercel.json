{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    },
    {
      "src": "api/**/*.js",
      "use": "@vercel/node"
    }
  ],
  "rewrites": [
    {
      "source": "/api/payhero/initiate",
      "destination": "/api/payhero/initiate.js"
    },
    {
      "source": "/api/payhero/callback",
      "destination": "/api/payhero/callback.js"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
